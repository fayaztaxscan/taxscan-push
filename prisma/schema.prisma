generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum SubscriberStatus {
  ACTIVE
  EXPIRED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
  EXPIRED
}

enum EventType {
  SENT
  DELIVERED
  CLICKED
  DISMISSED
  SUBSCRIBED
  UNSUBSCRIBED
  PROMPT_SHOWN
  PROMPT_ACCEPTED
  FAILED
}

enum UserRole {
  ADMIN
  PUBLISHER
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  USER_CREATED
  USER_DEACTIVATED
  USER_REACTIVATED
  USER_ROLE_CHANGED
  USER_PASSWORD_RESET
  USER_INVITED
  USER_INVITE_ACCEPTED
  CAMPAIGN_DISPATCHED
  CAMPAIGN_DISPATCH_FAILED
  REVIEW_APPROVED
  REVIEW_REJECTED
  REVIEW_PUSHED
}

model Subscriber {
  id        String           @id @default(cuid())
  portal    String           @default("taxscan")
  endpoint  String           @unique
  p256dh    String
  auth      String
  topics    String[]
  userAgent String?
  status    SubscriberStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  events Event[]

  @@index([portal])
  @@index([status])
}

model Campaign {
  id              String         @id @default(cuid())
  portal          String
  title           String
  body            String
  url             String
  icon            String?
  target          Json
  scheduledAt     DateTime?
  status          CampaignStatus @default(DRAFT)
  createdAt       DateTime       @default(now())
  createdByUserId String?

  // Editorial pacing (SEND_PACING_PLAN.md). Set by the RSS poller's classifier:
  // QUALIFIED (allow-list, auto-eligible) / FALLBACK (ITAT/CESTAT/NCLAT/NCLT —
  // filler only) / REVIEW (unclassified, awaiting an editor). Null for manual
  // /api/send campaigns and legacy rows. `authority` is the matched source
  // (e.g. "CESTAT", "Supreme Court") for ranking + display.
  sendQueue SendQueue?
  authority String?
  // The article's RSS <category> tags (e.g. ["Income Tax","Top Stories"]),
  // captured for the weekly/monthly coverage reports. Empty for manual sends.
  categories String[] @default([])
  // Set when an editor handles a REVIEW item (approve / reject / push-now). A
  // REVIEW DRAFT with reviewedAt = null is still pending in the review queue.
  reviewedAt DateTime?

  createdBy User?      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  events    Event[]
  feedItems FeedItem[]

  @@index([portal])
  @@index([status])
  @@index([scheduledAt])
  @@index([sendQueue])
}

enum SendQueue {
  QUALIFIED
  FALLBACK
  REVIEW
}

// Internal report-only recipients: emails that receive the weekly/monthly
// coverage report but have no login and no push subscription. App users (the
// User table) also receive it via their email; this is for extra internal members.
model ReportRecipient {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String
  role                  UserRole
  isActive              Boolean   @default(true)
  passwordResetRequired Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  lastLoginAt           DateTime?

  sessions    UserSession[]
  auditLogs   AuditLog[]
  campaigns   Campaign[]
  invitesSent UserInvite[]  @relation("InvitesSent")
}

// A pending invitation to join the admin. The real `User` row is created
// only when the recipient accepts (Phase 8). Until then this is the sole
// record of the invite — keyed by a single-use token whose SHA-256 hash is
// stored (same model as UserSession.tokenHash). `acceptedAt` is set when the
// invite is consumed; revoking deletes the row outright.
model UserInvite {
  id              String    @id @default(cuid())
  email           String
  role            UserRole
  tokenHash       String    @unique
  expiresAt       DateTime
  invitedByUserId String?
  invitedBy       User?     @relation("InvitesSent", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  acceptedAt      DateTime?
  acceptedUserId  String?
  createdAt       DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipAddress String?

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       AuditAction
  resourceType String?
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime    @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

// Per-article read counts synced from the GA4 Data API (src/services/gaReads.ts).
// One row per (portal, pagePath, date): `totalViews` = all pageviews GA saw for
// that path that day; `pushViews` = the subset from sessions GA attributes to our
// push UTM (sessionSource = taxscan-push). Written ONLY by the flag-gated sync
// cron — the request path (reports/campaigns) reads Postgres and never calls GA,
// so a GA outage just leaves counts stale, it can't slow or break the app.
model ArticleReadStat {
  id         String   @id @default(cuid())
  portal     String   @default("taxscan")
  pagePath   String
  date       DateTime @db.Date
  totalViews Int      @default(0)
  pushViews  Int      @default(0)
  fetchedAt  DateTime @default(now()) @updatedAt

  @@unique([portal, pagePath, date])
  @@index([date])
  @@index([pagePath])
}

model FeedItem {
  id         String   @id @default(cuid())
  feedUrl    String
  guid       String   @unique
  campaignId String?
  createdAt  DateTime @default(now())

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([feedUrl])
}

model Event {
  id           String    @id @default(cuid())
  campaignId   String?
  subscriberId String?
  type         EventType
  meta         Json?
  createdAt    DateTime  @default(now())

  campaign   Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  subscriber Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([subscriberId])
  @@index([type])
  @@index([createdAt])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum SubscriberStatus {
  ACTIVE
  EXPIRED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum EventType {
  SENT
  DELIVERED
  CLICKED
  DISMISSED
  SUBSCRIBED
  UNSUBSCRIBED
  PROMPT_SHOWN
  PROMPT_ACCEPTED
  FAILED
}

enum UserRole {
  ADMIN
  PUBLISHER
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  USER_CREATED
  USER_DEACTIVATED
  USER_REACTIVATED
  USER_ROLE_CHANGED
  USER_PASSWORD_RESET
  CAMPAIGN_DISPATCHED
  CAMPAIGN_DISPATCH_FAILED
}

model Subscriber {
  id        String           @id @default(cuid())
  portal    String           @default("taxscan")
  endpoint  String           @unique
  p256dh    String
  auth      String
  topics    String[]
  userAgent String?
  status    SubscriberStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  events Event[]

  @@index([portal])
  @@index([status])
}

model Campaign {
  id              String         @id @default(cuid())
  portal          String
  title           String
  body            String
  url             String
  icon            String?
  target          Json
  scheduledAt     DateTime?
  status          CampaignStatus @default(DRAFT)
  createdAt       DateTime       @default(now())
  createdByUserId String?

  createdBy User?      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  events    Event[]
  feedItems FeedItem[]

  @@index([portal])
  @@index([status])
  @@index([scheduledAt])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  sessions  UserSession[]
  auditLogs AuditLog[]
  campaigns Campaign[]
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipAddress String?

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       AuditAction
  resourceType String?
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime    @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model FeedItem {
  id         String   @id @default(cuid())
  feedUrl    String
  guid       String   @unique
  campaignId String?
  createdAt  DateTime @default(now())

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([feedUrl])
}

model Event {
  id           String    @id @default(cuid())
  campaignId   String?
  subscriberId String?
  type         EventType
  meta         Json?
  createdAt    DateTime  @default(now())

  campaign   Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  subscriber Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([subscriberId])
  @@index([type])
  @@index([createdAt])
}

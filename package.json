{
  "name": "taxscan-push",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted web push notification service for taxscan.in",
  "main": "dist/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json && npm run build:admin",
    "build:admin": "cd admin && npm ci --no-audit --no-fund && npm run build",
    "start": "prisma migrate deploy && node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "gen:vapid": "ts-node-dev --transpile-only --no-notify scripts/gen-vapid.ts",
    "db:cleanup-bad-keys": "ts-node-dev --transpile-only --no-notify --respawn=false scripts/cleanup-bad-keys.ts",
    "db:cleanup-e2e": "ts-node-dev --transpile-only --no-notify --respawn=false scripts/cleanup-e2e.ts",
    "db:cleanup-test-portals": "ts-node-dev --transpile-only --no-notify --respawn=false scripts/cleanup-test-portals.ts",
    "import:izooto": "ts-node-dev --transpile-only --no-notify --respawn=false scripts/import-izooto.ts",
    "create-admin": "ts-node-dev --transpile-only --no-notify --respawn=false scripts/create-admin.ts",
    "test": "jest"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "node-cron": "^4.2.1",
    "prisma": "^6.19.3",
    "rss-parser": "^3.13.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^30.4.2",
    "prettier": "^3.2.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}

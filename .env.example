# Server
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (Phase 1 — taxscan.in)
ALLOWED_ORIGINS=https://taxscan.in,https://www.taxscan.in,http://localhost:3000

# Database (Railway Postgres)
DATABASE_URL=postgresql://user:password@host:port/database

# VAPID keys for web-push — added in a later task
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@taxscan.in

# Admin UI auth — password used by /api/auth/login to issue ADMIN_TOKEN
ADMIN_PASSWORD=

# Bearer token for /api/send and the rest of the admin endpoints
ADMIN_TOKEN=

# Topic slug used by the admin "Send test" button; admins subscribe themselves
# to this topic from their dev browser to receive test pushes.
TEST_SEGMENT_TOPIC=test

# Sending behaviour
FREQ_CAP_PER_DAY=4
QUIET_HOURS_START=23:00
QUIET_HOURS_END=07:00
SEND_CONCURRENCY=10

# Cutover controls — see README "Cutover from iZooto" section.
# SEND_MODE=capture_only: RSS poller writes Campaigns as DRAFT without dispatching
# (keeps iZooto + this system from double-sending). Flip to 'live' to take over.
SEND_MODE=capture_only

# RSS poller (off by default — flip to true once subscribers exist)
RSS_ENABLED=false
RSS_POLL_CRON=*/5 * * * *

# Section feeds, one per topic. Pattern: RSS_FEED_<TOPIC>=<url>. The topic slug
# is the suffix lowercased with underscores → hyphens, so RSS_FEED_INCOME_TAX
# becomes topic `income-tax`. Add or remove a line to add/remove a section
# without code changes. If no RSS_FEED_* vars are set, the four taxscan.in
# section feeds below are used as the default.
RSS_FEED_CORPORATE=https://www.taxscan.in/corporate-laws/feed
RSS_FEED_GST=https://www.taxscan.in/cst-vat-gst/feed
RSS_FEED_INCOME_TAX=https://www.taxscan.in/income-tax/feed
RSS_FEED_CUSTOMS=https://www.taxscan.in/excise-customs/feed
# Available but not enabled by default:
#   RSS_FEED_SERVICE_TAX=https://www.taxscan.in/service-tax/feed
#   RSS_FEED_OTHER_TAXATIONS=https://www.taxscan.in/other-taxations/feed

# Scheduled-campaign sweeper (picks up quiet-hours-deferred campaigns)
SWEEPER_ENABLED=false
SWEEPER_CRON=* * * * *

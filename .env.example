# Server
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (Phase 1 — taxscan.in)
ALLOWED_ORIGINS=https://taxscan.in,https://www.taxscan.in,http://localhost:3000

# Database (Railway Postgres)
DATABASE_URL=postgresql://user:password@host:port/database

# VAPID keys for web-push — added in a later task
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@taxscan.in

# Admin UI auth — added in a later task
ADMIN_PASSWORD=

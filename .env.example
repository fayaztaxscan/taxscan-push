# Server
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (Phase 1 — taxscan.in)
ALLOWED_ORIGINS=https://taxscan.in,https://www.taxscan.in,http://localhost:3000

# Database (Railway Postgres). Append `?sslmode=require` in production for
# explicit TLS enforcement; Railway terminates TLS at the proxy either way.
# Tests use this same URL — never run `npm test` with this pointing at
# production. See README → "Tests touch the configured DATABASE_URL".
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# VAPID keys for web-push — added in a later task
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@taxscan.in

# Bearer token for cron / external scripts. /api/send and friends accept
# Authorization: Bearer $ADMIN_TOKEN. Admin SPA login uses per-user
# cookie sessions (Phase 2+) instead of this token.
ADMIN_TOKEN=

# Signs cookie sessions for the admin SPA. Required, must be at least
# 32 chars (startup self-check refuses to boot otherwise).
# Generate with: openssl rand -hex 32
SESSION_COOKIE_SECRET=

# Topic slug used by the admin "Send test" button; admins subscribe themselves
# to this topic from their dev browser to receive test pushes.
TEST_SEGMENT_TOPIC=test

# Email invites (Phase 8 — admin invites a teammate by email; they click a
# link to set their own password). All optional: if ELASTICEMAIL_API_KEY or
# EMAIL_FROM is unset, the invite still works but the admin copies the accept
# link to share manually instead of an email being sent.
#   APP_BASE_URL          — absolute origin the admin SPA is served from; used
#                           to build the invite link. Set to the deployed URL,
#                           e.g. https://taxscan-push-production.up.railway.app
#   ELASTICEMAIL_API_KEY  — ElasticEmail API key (transactional send).
#   EMAIL_FROM            — verified sender address in ElasticEmail.
#   EMAIL_FROM_NAME       — display name on the From header.
#   INVITE_TTL_HOURS      — how long an invite link stays valid (default 72).
APP_BASE_URL=
ELASTICEMAIL_API_KEY=
EMAIL_FROM=no-reply@taxscan.in
EMAIL_FROM_NAME=Taxscan Push
INVITE_TTL_HOURS=72

# Sending behaviour
FREQ_CAP_PER_DAY=4
# Minimum minutes between two notifications to the SAME subscriber. Prevents
# burst fatigue (and the unsubscribes it causes) when several articles publish
# close together — a subscriber pushed within this window is skipped for the
# next campaign. Complements FREQ_CAP_PER_DAY (which caps daily volume, not
# spacing). Set to 0 to disable the cooldown.
MIN_GAP_MINUTES=30
QUIET_HOURS_START=23:00
QUIET_HOURS_END=07:00
SEND_CONCURRENCY=10

# Cutover controls — see README "Cutover from iZooto" section.
# SEND_MODE=capture_only: RSS poller writes Campaigns as DRAFT without dispatching
# (keeps iZooto + this system from double-sending). Flip to 'live' to take over.
SEND_MODE=capture_only

# RSS poller (off by default — flip to true once subscribers exist)
RSS_ENABLED=false
RSS_POLL_CRON=*/5 * * * *

# Editorial pacing (SEND_PACING_PLAN.md). Both default off so the code ships dark.
# Stage 1 — classifier filter: when true, the poller classifies each article by
# title and (in live mode) only QUALIFIED allow-list items are eligible to send;
# ITAT/CESTAT/NCLAT/NCLT (FALLBACK) and unclassified (REVIEW) are held as DRAFT.
RSS_EDITORIAL_FILTER=false
# Stage 2 — pacer: when true (requires RSS_EDITORIAL_FILTER=true) the poller
# QUEUES qualified articles as DRAFT and the pacer releases one per spacing slot,
# best-first, up to the daily ceiling. Replaces the per-subscriber cooldown — set
# MIN_GAP_MINUTES=0 when enabling the pacer.
PACER_ENABLED=false
PACER_CRON=* * * * *
SEND_SPACING_MINUTES=45
DAILY_SEND_CEILING=20

# Morning backfill: fill otherwise-empty morning slots from YESTERDAY's articles
# (re-send SC → Bombay HC → other HC first, then unsent other-category, then
# best-clicked other-category), only until the first fresh qualified article of
# the day publishes. Each yesterday item is re-used at most once per day.
MORNING_BACKFILL_ENABLED=false
MORNING_BACKFILL_UNTIL=12:00

# Section feeds, one per topic. Pattern: RSS_FEED_<TOPIC>=<url>. The topic slug
# is the suffix lowercased with underscores → hyphens, so RSS_FEED_INCOME_TAX
# becomes topic `income-tax`. Add or remove a line to add/remove a section
# without code changes. If no RSS_FEED_* vars are set, the four taxscan.in
# section feeds below are used as the default.
RSS_FEED_CORPORATE=https://www.taxscan.in/corporate-laws/feed
RSS_FEED_GST=https://www.taxscan.in/cst-vat-gst/feed
RSS_FEED_INCOME_TAX=https://www.taxscan.in/income-tax/feed
RSS_FEED_CUSTOMS=https://www.taxscan.in/excise-customs/feed
# Job-scan (recruitment) feed. Job posts always classify to REVIEW (an editor
# decides whether to push) and target ALL subscribers when sent — there is no
# "jobs" topic to opt into.
RSS_FEED_JOBS=https://www.taxscan.in/job-scan/feed
# Available but not enabled by default:
#   RSS_FEED_SERVICE_TAX=https://www.taxscan.in/service-tax/feed
#   RSS_FEED_OTHER_TAXATIONS=https://www.taxscan.in/other-taxations/feed

# Scheduled-campaign sweeper (picks up quiet-hours-deferred campaigns)
SWEEPER_ENABLED=false
SWEEPER_CRON=* * * * *

# AuditLog retention sweeper. Default ON; set to "false" to disable.
# Cron is interpreted in Asia/Kolkata (same TZ as the RSS poller).
# Two windows: LOGIN_FAILED rows expire faster (noisier) than others.
AUDIT_LOG_SWEEPER_ENABLED=true
AUDIT_LOG_SWEEPER_CRON=0 3 * * *
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_FAILED_LOGIN_RETENTION_DAYS=30

# Security
# Comma-separated host allowlist for push payload click URLs. /api/send 400s
# when the `url` host isn't on this list. Default keeps subscribers off-site
# redirect-proof; widen only if you syndicate links from other hosts.
ALLOWED_PUSH_HOSTS=taxscan.in,www.taxscan.in
# Per-IP rate limits (requests per minute). Public endpoints (subscribe /
# track / unsubscribe / config) share a single bucket; admin login is
# separate and stricter.
RATE_LIMIT_PUBLIC_PER_MIN=60
RATE_LIMIT_LOGIN_PER_MIN=5

# Analytics — UTM tags appended to the push click URL so Google Analytics
# attributes notification clicks (otherwise GA lumps them into (direct)/(none)).
# Defaults give a `taxscan-push / push_notifications` row in GA's Traffic
# acquisition report, directly comparable to the old `izooto / push_notifications`.
# Set either to empty to disable that tag.
UTM_SOURCE=taxscan-push
UTM_MEDIUM=push_notifications
